# frozen_string_literal: true

require "fileutils"

default_platform(:mac)

platform :mac do
  desc "Build and release to App Store Connect"
  lane :release do
    setup_ci(force: true)

    # Configure App Store Connect API key from environment variables
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_API_KEY_PATH"]
    )

    # Fetch signing certificates via match
    # keychain is automatically managed by setup_ci
    match(
      type: "appstore",
      readonly: true,
      additional_cert_types: ["mac_installer_distribution"],
      verbose: true
    )

    # Update code signing settings to use manual signing
    # Get profile name and certificate name from match result
    profile_name = ENV["sigh_cc.focuswave.Flowease_appstore_macos_profile-name"]
    certificate_name = ENV["sigh_cc.focuswave.Flowease_appstore_macos_certificate-name"]
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Flowease.xcodeproj",
      team_id: "P785AMQPKJ",
      bundle_identifier: "cc.focuswave.Flowease",
      profile_name: profile_name,
      code_sign_identity: certificate_name
    )

    # Get version from git tag
    tag = last_git_tag
    UI.user_error!("No git tag found. Please create a version tag (e.g., v1.0.0)") if tag.nil? || tag.empty?
    version = tag.sub(/^v/, "")

    # Update marketing version
    increment_version_number(
      version_number: version,
      xcodeproj: "Flowease.xcodeproj"
    )

    # Increment build number using GitHub Actions run number
    increment_build_number(
      build_number: ENV["GITHUB_RUN_NUMBER"],
      xcodeproj: "Flowease.xcodeproj"
    )

    # Build the app
    build_mac_app(
      scheme: "Flowease",
      export_method: "app-store",
      output_directory: "build",
      output_name: "Flowease",
      xcargs: "-allowProvisioningUpdates CODE_SIGN_STYLE=Manual"
    )

    # Upload to TestFlight (App Store Connect)
    upload_to_testflight(
      api_key: api_key,
      app_identifier: "cc.focuswave.Flowease",
      pkg: "build/Flowease.pkg",
      skip_waiting_for_build_processing: true
    )

    # Note: pkg is already at build/Flowease.pkg for GitHub Release artifact
  end
end
