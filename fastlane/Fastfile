# frozen_string_literal: true

require "fileutils"

default_platform(:mac)

platform :mac do
  desc "Build and release to App Store Connect"
  lane :release do
    setup_ci

    # App Store Connect API キー設定
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_API_KEY_PATH"]
    )

    # 証明書取得
    match(type: "appstore", readonly: true)

    # バージョン取得（タグから）
    tag = last_git_tag
    UI.user_error!("No git tag found. Please create a version tag (e.g., v1.0.0)") if tag.nil? || tag.empty?
    version = tag.sub(/^v/, "")

    # マーケティングバージョンを更新
    increment_version_number(
      version_number: version,
      xcodeproj: "Flowease.xcodeproj"
    )

    # ビルド番号をインクリメント（タイムスタンプベース）
    increment_build_number(
      build_number: Time.now.strftime("%Y%m%d%H%M"),
      xcodeproj: "Flowease.xcodeproj"
    )

    # ビルド
    build_mac_app(
      scheme: "Flowease",
      export_method: "app-store",
      output_directory: "build",
      output_name: "Flowease"
    )

    # App Store Connect にアップロード
    upload_to_app_store(
      skip_metadata: true,
      skip_screenshots: true,
      precheck_include_in_app_purchases: false
    )

    # GitHub Releases 用に zip 作成（.pkg を優先）
    pkg_path = "build/Flowease.pkg"
    app_path = "build/Flowease.app"

    artifact_path = if File.exist?(pkg_path)
                      pkg_path
                    elsif File.exist?(app_path)
                      app_path
                    else
                      UI.user_error!("Build artifact not found in build/")
                    end

    if artifact_path.end_with?(".app")
      zip(
        path: artifact_path,
        output_path: "build/Flowease-#{version}.zip"
      )
    else
      FileUtils.cp(artifact_path, "build/Flowease-#{version}.pkg")
    end
  end
end
