#!/bin/bash

# SwiftFormat - 自動修正してステージング
if which swiftformat > /dev/null; then
  # 変更されたSwiftファイルのみを対象
  git diff --cached --name-only --diff-filter=ACM | grep '\.swift$' | while read file; do
    if ! swiftformat "$file"; then
      echo "Error: swiftformat failed on $file"
      exit 1
    fi
    git add "$file"
  done || exit 1
fi

# SwiftLint - チェック（エラーがあればコミット中断）
if which swiftlint > /dev/null; then
  STAGED_SWIFT_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.swift$' || true)
  if [ -n "$STAGED_SWIFT_FILES" ]; then
    echo "$STAGED_SWIFT_FILES" | xargs swiftlint lint --quiet
    RESULT=$?
    if [ $RESULT -ne 0 ]; then
      echo "SwiftLint found issues. Please fix them before committing."
      exit 1
    fi
  fi
fi

exit 0
